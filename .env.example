# --- Base de datos ---
# Cadena de conexión a PostgreSQL. En Docker Compose usa el host "db".
DATABASE_URL="postgresql://asistencia:asistencia@localhost:5432/asistencia_ajedrez?schema=public"

# --- NextAuth ---
# URL pública de la aplicación (sin barra final).
NEXTAUTH_URL="http://localhost:3000"
# Secreto usado para firmar cookies/tokens. Genera uno con: openssl rand -base64 32
NEXTAUTH_SECRET="cambia-este-valor-por-un-secreto-aleatorio-largo"

# --- Usuario administrador inicial (solo se usa en el seed) ---
# No uses contraseñas reales en el repositorio. El seed crea este usuario con
# la contraseña indicada aquí y fuerza el cambio de contraseña en el primer inicio de sesión.
ADMIN_EMAIL="admin@example.com"
ADMIN_USERNAME="admin"
ADMIN_PASSWORD="CambiaEstaClave123!"

# --- Seguridad de login ---
# Nº máximo de intentos fallidos antes de bloquear temporalmente el usuario/IP.
LOGIN_MAX_ATTEMPTS=5
# Minutos que dura el bloqueo temporal tras superar el máximo de intentos.
LOGIN_LOCKOUT_MINUTES=15
# Minutos de validez de un token de restablecimiento de contraseña.
PASSWORD_RESET_TOKEN_MINUTES=60

# --- Correo saliente (opcional) ---
# Si no se configura, los enlaces de restablecimiento de contraseña se registran
# en la consola del servidor y se muestran en una pantalla de confirmación (solo en desarrollo).
SMTP_HOST=""
SMTP_PORT="587"
SMTP_USER=""
SMTP_PASSWORD=""
SMTP_FROM="Asistencia Ajedrez <no-reply@example.com>"

# --- PostgreSQL (usado por docker-compose.yml) ---
POSTGRES_USER="asistencia"
POSTGRES_PASSWORD="asistencia"
POSTGRES_DB="asistencia_ajedrez"
