generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ---------------------------------------------------------------------------
// Autenticación (NextAuth / Auth.js) + seguridad de acceso
// ---------------------------------------------------------------------------

model User {
  id                 String   @id @default(cuid())
  name               String
  email              String   @unique
  username           String   @unique
  passwordHash       String
  isActive           Boolean  @default(true)
  mustChangePassword Boolean  @default(false)
  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt

  roles               UserRole[]
  permissionOverrides UserPermission[]
  schools             UserSchool[]
  sessions            Session[]
  accounts            Account[]
  passwordResetTokens PasswordResetToken[]

  createdAttendances Attendance[]     @relation("AttendanceCreatedBy")
  updatedAttendances Attendance[]     @relation("AttendanceUpdatedBy")
  createdPayments    MonthlyPayment[] @relation("PaymentCreatedBy")
  updatedPayments    MonthlyPayment[] @relation("PaymentUpdatedBy")
  auditLogs          AuditLog[]

  @@index([isActive])
}

model Role {
  id          String  @id @default(cuid())
  key         String  @unique
  name        String
  description String?

  users       UserRole[]
  permissions RolePermission[]
}

model Permission {
  id          String  @id @default(cuid())
  key         String  @unique
  description String?

  roles         RolePermission[]
  userOverrides UserPermission[]
}

model UserRole {
  userId String
  roleId String

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
  role Role @relation(fields: [roleId], references: [id], onDelete: Cascade)

  @@id([userId, roleId])
}

model RolePermission {
  roleId       String
  permissionId String

  role       Role       @relation(fields: [roleId], references: [id], onDelete: Cascade)
  permission Permission @relation(fields: [permissionId], references: [id], onDelete: Cascade)

  @@id([roleId, permissionId])
}

// Sobrescritura de permisos por usuario. granted=true concede el permiso aunque
// el rol no lo incluya; granted=false lo revoca aunque el rol lo incluya.
model UserPermission {
  userId       String
  permissionId String
  granted      Boolean

  user       User       @relation(fields: [userId], references: [id], onDelete: Cascade)
  permission Permission @relation(fields: [permissionId], references: [id], onDelete: Cascade)

  @@id([userId, permissionId])
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String? @db.Text
  access_token      String? @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String? @db.Text
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

model PasswordResetToken {
  id        String    @id @default(cuid())
  userId    String
  tokenHash String    @unique
  expiresAt DateTime
  usedAt    DateTime?
  createdAt DateTime  @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

model LoginAttempt {
  id         String   @id @default(cuid())
  identifier String
  ipAddress  String
  success    Boolean
  createdAt  DateTime @default(now())

  @@index([identifier, createdAt])
  @@index([ipAddress, createdAt])
}

// ---------------------------------------------------------------------------
// Dominio: colegios, alumnos, asistencia, pagos
// ---------------------------------------------------------------------------

enum SchoolStatus {
  ACTIVE
  ARCHIVED
}

enum StudentStatus {
  ACTIVE
  INACTIVE
  ARCHIVED
}

enum AttendanceStatus {
  PRESENT
  ABSENT
  JUSTIFIED
  CANCELLED
  MAKEUP
  UNRECORDED
}

enum PaymentStatus {
  PENDING
  PAID
  PARTIAL
  EXEMPT
  NOT_APPLICABLE
}

enum PaymentMethod {
  CASH
  TRANSFER
  BIZUM
  CARD
  OTHER
}

model School {
  id           String       @id @default(cuid())
  name         String
  address      String?
  locality     String?
  contactName  String?
  contactPhone String?
  contactEmail String?
  notes        String?
  status       SchoolStatus @default(ACTIVE)
  createdAt    DateTime     @default(now())
  updatedAt    DateTime     @updatedAt

  users       UserSchool[]
  groups      ClassGroup[]
  students    Student[]
  attendances Attendance[]
  payments    MonthlyPayment[]

  @@index([name])
  @@index([status])
}

model UserSchool {
  userId   String
  schoolId String

  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)
  school School @relation(fields: [schoolId], references: [id], onDelete: Cascade)

  @@id([userId, schoolId])
}

// Grupo/clase dentro de un colegio. Cada colegio recibe un grupo "General"
// automático para alumnos sin grupo específico (ver seed y lógica de alta de alumno).
model ClassGroup {
  id        String   @id @default(cuid())
  schoolId  String
  name      String
  weekday   Int?
  startTime String?
  endTime   String?
  isDefault Boolean  @default(false)
  createdAt DateTime @default(now())

  school      School       @relation(fields: [schoolId], references: [id], onDelete: Cascade)
  students    Student[]
  attendances Attendance[]

  @@unique([schoolId, name])
}

model Student {
  id            String        @id @default(cuid())
  schoolId      String
  groupId       String
  firstName     String
  lastName      String
  weekday       Int?
  schedule      String?
  enrollDate    DateTime      @default(now())
  status        StudentStatus @default(ACTIVE)
  guardianName  String?
  guardianPhone String?
  guardianEmail String?
  notes         String?
  createdAt     DateTime      @default(now())
  updatedAt     DateTime      @updatedAt

  school      School           @relation(fields: [schoolId], references: [id])
  group       ClassGroup       @relation(fields: [groupId], references: [id])
  attendances Attendance[]
  payments    MonthlyPayment[]

  @@index([schoolId, status])
  @@index([lastName, firstName])
}

model Attendance {
  id            String           @id @default(cuid())
  studentId     String
  schoolId      String
  classGroupId  String
  classDate     DateTime         @db.Date
  status        AttendanceStatus @default(UNRECORDED)
  note          String?
  createdByUserId String
  updatedByUserId String?
  createdAt     DateTime         @default(now())
  updatedAt     DateTime         @updatedAt

  student    Student    @relation(fields: [studentId], references: [id])
  school     School     @relation(fields: [schoolId], references: [id])
  classGroup ClassGroup @relation(fields: [classGroupId], references: [id])
  createdBy  User       @relation("AttendanceCreatedBy", fields: [createdByUserId], references: [id])
  updatedBy  User?      @relation("AttendanceUpdatedBy", fields: [updatedByUserId], references: [id])

  @@unique([studentId, classDate])
  @@index([schoolId, classDate])
  @@index([classGroupId, classDate])
}

model MonthlyPayment {
  id              String        @id @default(cuid())
  studentId       String
  schoolId        String
  month           Int
  year            Int
  status          PaymentStatus @default(PENDING)
  expectedAmount  Decimal       @default(0) @db.Decimal(10, 2)
  paidAmount      Decimal       @default(0) @db.Decimal(10, 2)
  paymentDate     DateTime?
  method          PaymentMethod?
  notes           String?
  createdByUserId String
  updatedByUserId String?
  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt

  student   Student @relation(fields: [studentId], references: [id])
  school    School  @relation(fields: [schoolId], references: [id])
  createdBy User    @relation("PaymentCreatedBy", fields: [createdByUserId], references: [id])
  updatedBy User?   @relation("PaymentUpdatedBy", fields: [updatedByUserId], references: [id])

  @@unique([studentId, month, year])
  @@index([schoolId, year, month])
}

model AuditLog {
  id         String   @id @default(cuid())
  userId     String?
  action     String
  entityType String
  entityId   String?
  beforeData Json?
  afterData  Json?
  ipAddress  String?
  createdAt  DateTime @default(now())

  user User? @relation(fields: [userId], references: [id], onDelete: SetNull)

  @@index([entityType, entityId])
  @@index([userId])
  @@index([createdAt])
}
